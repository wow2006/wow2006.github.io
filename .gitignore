# Generated files by hugo
/public/
/resources/_gen/
/assets/jsconfig.json
hugo_stats.json

# Executable may be added to repository
hugo.exe
hugo.darwin
hugo.linux

# Temporary lock file while building
/.hugo_build.lock

# Build output from the example programs under assets/code/. Hugo watches
# assets/, so these also keep the watcher out of Cargo's target dir.
/assets/code/**/target/
/assets/code/**/*.o
/assets/code/**/test.mkv
